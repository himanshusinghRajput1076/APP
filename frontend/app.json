{
  "expo": {
    "name": "IDEACON",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ideacon",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emergent.futurelaunchpad.wb2mxs",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload your ID card & profile photo",
        "NSCameraUsageDescription": "Capture your ID card & profile photo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#050505"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.emergent.futurelaunchpad.wb2mxs",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050505"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload your ID card & profile photo"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
    ,"extra": {
      "EXPO_PUBLIC_BACKEND_URL": "http://127.0.0.1:8002"
    }
  }
}
